# ESP-IDF build output
build/
build_sensor/
sdkconfig
sdkconfig.sensor
sdkconfig.old

# IDF component manager (regenerated on demand)
managed_components/
dependencies.lock

# clangd / IDE caches
.cache/
.idea/
.vscode/

# Editors
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Python bytecode (tools/factory_flash_helpers and friends)
__pycache__/
*.pyc

# Per-device MQTT client certs embedded into the firmware at build time.
# Issued by `gen_certs.sh device <id>` on the prod host (see dockpulse repo).
certs/

# Factory signing key (private). Pubkey gets distributed to backend as
# FACTORY_PUBKEY env. Privkey lives only on the provisioning host and
# never gets committed.
factory/private/
# Per-device factory artefacts: OOB blob, NVS image, QR PNG, claim.json.
# One subdir per serial; safe to wipe after the operator has the printed
# sticker.
factory/devices/
